---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.svelte';
import Profile from '../components/widget/Profile.astro';
import Announcement from '../components/widget/Announcement.astro';
import SiteStats from '../components/widget/SiteStats.astro';
import Categories from '../components/widget/Categories.astro';
import Tags from '../components/widget/Tags.astro';
import SeriesList from '../components/widget/SeriesList.astro';
import LastFm from '../components/widget/LastFm.svelte';
import Discord from '../components/widget/Discord.svelte';
import Calendar from '../components/widget/Calendar.svelte';
import ReadingList from '../components/widget/ReadingList.svelte';
import { getSortedPosts, formatDate, formatDateTime, slugify } from '../utils/content-utils';
const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
import { SITE } from '../config';

const posts = await getSortedPosts();
const [featured, ...rest] = posts || [];

// derive categories: count, latest image, gradient, glyph
// posts are already sorted newest-first, so first match per category = latest
const catMap = new Map<string, { count: number; image: string; gradient: string; glyph: string }>();
for (const p of posts) {
  if (!p.data.category) continue;
  const cat = p.data.category;
  if (!catMap.has(cat)) {
    catMap.set(cat, {
      count: 0,
      image: p.data.image ?? '',
      gradient: p.data.gradient ?? '',
      glyph: p.data.glyph ?? '✦',
    });
  }
  catMap.get(cat)!.count++;
}
const showcaseCategories = [...catMap.entries()]
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 4);
---

<Layout pathname="/">
  <Banner client:load title={SITE.title} />
  <div class="grid three-col">
    <aside class="sidebar">
      <Profile />
      <Announcement />
      <SiteStats />
      <Categories />
      <Tags />
      <SeriesList />
      <ReadingList client:visible />
    </aside>

    <main>
      <!-- ── Featured post ────────────────────────────── -->
      {featured && (
        <article class="post-featured">
          <a href={`/posts/${featured.id}`} class="post-card-link" aria-label={`Read: ${featured.data.title}`} data-astro-prefetch></a>
          <div
            class="featured-bg"
            style={featured.data.image
              ? `background-image:url(${featured.data.image})`
              : featured.data.gradient
                ? `background:${featured.data.gradient}`
                : 'background:var(--primary-soft)'}
          ></div>
          <div class="featured-overlay">
            <div class="featured-top">
              <span class="featured-badge">Latest</span>
              {featured.data.series && <span class="series-badge">{featured.data.series}</span>}
            </div>
            <div class="featured-bottom">
              <div class="featured-meta">
                <span>{formatDate(featured.data.published)}</span>
                {featured.data.category && <>
                  <span class="meta-dot">·</span>
                  <a href={`/category/${slugify(featured.data.category)}`} class="featured-cat">{featured.data.category}</a>
                </>}
                {featured.data.readTime && <>
                  <span class="meta-dot">·</span>
                  <span>{featured.data.readTime} read</span>
                </>}
              </div>
              <h2 class="featured-title">
                {featured.data.title}
                {featured.data.titleTinted && <span class="featured-tinted"> {featured.data.titleTinted}</span>}
              </h2>
              {featured.data.description && <p class="featured-desc">{featured.data.description}</p>}
            </div>
          </div>
        </article>
      )}

      <!-- ── Category showcase ─────────────────────────── -->
      {showcaseCategories.length > 0 && (
        <section class="cat-showcase">
          <div class="cat-showcase-header">
            <span class="cat-showcase-label">Browse by category</span>
          </div>
          <div class="cat-showcase-grid">
            {showcaseCategories.map(([name, { count, image, gradient, glyph }]) => (
              <a href={`/category/${slugify(name)}`} class={`cat-card ${image ? 'cat-card-photo' : ''}`}>
                {image && <img src={image} alt={name} class="cat-card-img" loading="lazy" />}
                {!image && (
                  <div class="cat-icon" style={gradient ? `background:${gradient}` : 'background:var(--primary-soft)'}>
                    <span class="cat-icon-glyph">{glyph}</span>
                  </div>
                )}
                <div class={`cat-info ${image ? 'cat-info-photo' : ''}`}>
                  <span class="cat-name">{name}</span>
                  <span class="cat-count">{count} {count === 1 ? 'post' : 'posts'}</span>
                </div>
                <iconify-icon icon="material-symbols:chevron-right-rounded" width="18" class={`cat-arrow ${image ? 'cat-arrow-photo' : ''}`}></iconify-icon>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ── Post list ──────────────────────────────── -->
      <div class="post-list-header">
        <span class="post-list-label">Latest posts</span>
        <span class="post-list-count">{rest.length} posts</span>
      </div>

      {rest.map((post, i) => (
        <article class={`pcard${post.data.encrypted ? ' pcard-locked' : ''}`} style={`animation-delay:${i * 40}ms`}>

          <div class="pcard-index" aria-hidden="true">
            <span class="pcard-num">{String(i + 2).padStart(2, '0')}</span>
            <time class="pcard-date" datetime={post.data.published.toISOString()}>
              {formatDate(post.data.published)}
            </time>
          </div>

          <div class="pcard-body">
            <div class="pcard-eyebrow">
              {post.data.encrypted && (
                <span class="pcard-badge-lock">
                  <iconify-icon icon="material-symbols:lock-outline" width="9"></iconify-icon>
                  LOCKED
                </span>
              )}
              {post.data.unlockAt && new Date() < post.data.unlockAt && (
                <span class="pcard-badge-lock">
                  <iconify-icon icon="material-symbols:schedule" width="9"></iconify-icon>
                  UNLOCKS {formatDateTime(post.data.unlockAt)}
                </span>
              )}
              {post.data.category && (
                <a href={`/category/${slugify(post.data.category)}`} class="pcard-cat" data-astro-prefetch>
                  <iconify-icon icon="material-symbols:bookmark-outline" width="10"></iconify-icon>
                  {post.data.category}
                </a>
              )}
              {post.data.series && <span class="pcard-series">{post.data.series}</span>}
              {post.data.readTime && <span class="pcard-read">{post.data.readTime}</span>}
            </div>
            <h3 class="pcard-title">
              <a href={`/posts/${post.id}`} data-astro-prefetch>
                {post.data.title}
                {post.data.titleTinted && <span class="pcard-tint"> {post.data.titleTinted}</span>}
              </a>
            </h3>
            <p class="pcard-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="pcard-tags">
                {post.data.tags.slice(0, 3).map(tag => (
                  <a href={`/tag/${slugify(tag)}`} class="pcard-tag" data-astro-prefetch>#{tag}</a>
                ))}
              </div>
            )}
          </div>

          <a href={`/posts/${post.id}`} class="pcard-media" tabindex="-1" aria-hidden="true" data-astro-prefetch>
            {post.data.image
              ? <div class="pcard-photo">
                  <img src={post.data.image} alt={post.data.title} loading="lazy" width="130" height="130" />
                  <div class="pcard-photo-veil"></div>
                  <iconify-icon icon="material-symbols:chevron-right-rounded" width="28" class="pcard-photo-chevron"></iconify-icon>
                </div>
              : <div class="pcard-enter">
                  <iconify-icon icon="material-symbols:chevron-right-rounded" width="22" class="pcard-chevron"></iconify-icon>
                </div>
            }
          </a>
        </article>
      ))}
    </main>

    <aside class="sidebar-right">
      <LastFm client:load />
      <Discord client:load />
      <Calendar client:load postDates={posts.map(p => ({
        date: p.data.published.toISOString().slice(0, 10),
        id: p.id,
        title: p.data.title,
      }))} />
    </aside>
  </div>
</Layout>

<style>
  /* ── Featured post ─────────────────────────────────────── */
  .post-featured {
    position: relative;
    border-radius: var(--radius-large);
    overflow: hidden;
    height: 340px;
    margin-bottom: 20px;
    cursor: pointer;
    animation: card-in 400ms cubic-bezier(.4,0,.2,1) both;
  }
  .post-featured .post-card-link { z-index: 2; }
  .post-featured:hover .featured-bg { transform: scale(1.04); }
  .post-featured:hover .featured-title { color: oklch(0.95 0.06 var(--hue)); }

  .featured-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    transition: transform 500ms cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }

  .featured-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.1) 0%,
      transparent 30%,
      transparent 40%,
      rgba(0,0,0,0.6) 75%,
      rgba(0,0,0,0.82) 100%
    );
    display: flex; flex-direction: column;
    justify-content: space-between;
    padding: 20px 24px;
    z-index: 1;
    pointer-events: none;
  }
  .featured-overlay * { pointer-events: auto; }

  .featured-top { display: flex; gap: 8px; align-items: center; }
  .featured-badge {
    font-size: 10px; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 3px 10px;
    background: var(--primary); color: white;
    border-radius: 999px;
  }
  .series-badge {
    font-size: 10px; font-weight: 600; letter-spacing: 0.04em;
    padding: 3px 10px; border-radius: 999px;
    background: rgba(255,255,255,0.18); color: white;
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(6px);
  }
  .featured-bottom { display: flex; flex-direction: column; gap: 8px; }
  .featured-meta {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: rgba(255,255,255,0.7);
    font-family: var(--font-mono);
  }
  .meta-dot { color: rgba(255,255,255,0.35); }
  .featured-cat {
    position: relative; z-index: 3;
    color: rgba(255,255,255,0.85); text-decoration: none;
    transition: color 120ms;
  }
  .featured-cat:hover { color: oklch(0.92 0.12 var(--hue)); }
  .featured-title {
    font-family: var(--font-display); font-weight: 700;
    font-size: 28px; line-height: 1.2;
    color: white;
    text-shadow: 0 2px 12px rgba(0,0,0,0.5);
    margin: 0; transition: color 250ms;
  }
  .featured-tinted { color: oklch(0.88 0.12 var(--hue)); }
  .featured-desc {
    font-size: 14px; color: rgba(255,255,255,0.75);
    line-height: 1.5; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* ── Category showcase ─────────────────────────────────── */
  .cat-showcase { margin-bottom: 24px; }
  .cat-showcase-header { margin-bottom: 10px; }
  .cat-showcase-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--fg-2);
  }
  .cat-showcase-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  /* base card — plain gradient variant */
  .cat-card {
    position: relative;
    display: flex; align-items: center; gap: 12px;
    padding: 12px 14px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-large);
    text-decoration: none; overflow: hidden;
    transition: border-color 150ms, transform 150ms, box-shadow 150ms;
  }
  .cat-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }

  /* photo variant — image fills card */
  .cat-card-photo {
    height: 72px;
    padding: 0 14px;
    border-color: transparent;
    gap: 10px;
  }
  .cat-card-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 300ms cubic-bezier(.4,0,.2,1);
  }
  .cat-card-photo:hover .cat-card-img { transform: scale(1.05); }
  .cat-card-photo::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.45) 55%, rgba(0,0,0,0.15) 100%);
  }
  .cat-card-photo > * { position: relative; z-index: 1; }

  /* icon square (shown only for non-photo cards) */
  .cat-icon {
    width: 44px; height: 44px; flex-shrink: 0;
    border-radius: 0.75rem;
    display: flex; align-items: center; justify-content: center;
  }
  .cat-icon-glyph { font-size: 22px; }

  /* text */
  .cat-info { flex: 1; min-width: 0; }
  .cat-name {
    display: block;
    font-family: var(--font-display); font-weight: 700;
    font-size: 14px; color: var(--fg-1); line-height: 1.2;
  }
  .cat-count { font-size: 11px; color: var(--fg-2); font-family: var(--font-mono); }
  .cat-info-photo .cat-name { color: white; text-shadow: 0 1px 4px rgba(0,0,0,0.5); }
  .cat-info-photo .cat-count { color: rgba(255,255,255,0.65); }

  /* arrow */
  .cat-arrow { color: var(--fg-4); transition: color 120ms, transform 120ms; flex-shrink: 0; }
  .cat-card:hover .cat-arrow { color: var(--primary); transform: translateX(2px); }
  .cat-arrow-photo { color: rgba(255,255,255,0.5); }
  .cat-card-photo:hover .cat-arrow-photo { color: white; }

  /* ── Post list header ──────────────────────────────────── */
  .post-list-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px;
  }
  .post-list-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--fg-2);
  }
  .post-list-count {
    font-size: 11px; color: var(--fg-2); font-family: var(--font-mono);
  }

  /* ── Editorial post cards ──────────────────────────────── */
  .pcard {
    position: relative;
    display: grid;
    grid-template-columns: 68px 1fr auto;
    align-items: stretch;
    background: var(--card-bg);
    border-radius: var(--radius-large);
    border: 1px solid var(--border);
    margin-bottom: 12px;
    overflow: hidden;
    animation: pcard-in 220ms cubic-bezier(.4,0,.2,1) both;
    transition: box-shadow 180ms, transform 150ms, border-color 150ms;
  }
  .pcard:hover {
    border-color: var(--primary);
    box-shadow: 0 8px 28px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  @keyframes pcard-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: none; }
  }

  /* Left index column */
  .pcard-index {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 10px; padding: 20px 0;
    background: var(--primary-soft);
    border-right: 1px solid var(--border);
    transition: background 150ms;
  }
  .pcard:hover .pcard-index { background: var(--btn-regular-bg-hover); }
  .pcard-num {
    font-family: var(--font-mono); font-weight: 800;
    font-size: 20px; color: var(--primary); letter-spacing: -0.02em;
    line-height: 1;
  }
  .pcard-date {
    font-family: var(--font-mono); font-size: 11.5px;
    color: var(--fg-3); writing-mode: vertical-rl;
    text-orientation: mixed; letter-spacing: 0.08em;
    text-transform: uppercase; line-height: 1;
  }

  /* Locked post card */
  .pcard-locked { border-color: oklch(0.62 0.18 45 / 0.4); }
  .pcard-locked:hover { border-color: oklch(0.62 0.18 45); box-shadow: 0 8px 28px oklch(0.62 0.18 45 / 0.12); }
  .pcard-locked .pcard-index {
    background: oklch(0.92 0.06 45 / 0.6);
    border-right-color: oklch(0.62 0.18 45 / 0.25);
  }
  .dark .pcard-locked .pcard-index { background: oklch(0.28 0.06 45 / 0.5); }
  .pcard-locked:hover .pcard-index { background: oklch(0.88 0.08 45 / 0.7); }
  .dark .pcard-locked:hover .pcard-index { background: oklch(0.32 0.07 45 / 0.6); }

  .pcard-badge-lock {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 9px; font-weight: 800; letter-spacing: 0.10em;
    text-transform: uppercase;
    color: oklch(0.40 0.18 45);
    background: oklch(0.92 0.08 45 / 0.7);
    border: 1px solid oklch(0.62 0.18 45 / 0.35);
    padding: 2px 7px; border-radius: 999px;
  }
  .dark .pcard-badge-lock {
    color: oklch(0.82 0.14 45);
    background: oklch(0.28 0.06 45 / 0.6);
    border-color: oklch(0.62 0.18 45 / 0.4);
  }

  /* Center body */
  .pcard-body {
    padding: 20px 18px; min-width: 0;
    display: flex; flex-direction: column; gap: 6px;
  }
  .pcard-eyebrow {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    position: relative; z-index: 1;
  }
  .pcard-cat {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 10px; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.09em; color: oklch(0.49 0.15 var(--hue));
    text-decoration: none;
    transition: opacity 120ms;
    min-height: 24px; padding-block: 5px;
  }
  .dark .pcard-cat { color: var(--primary); }
  .pcard-cat:hover { opacity: 0.7; }
  .pcard-series {
    font-size: 10px; padding: 1px 7px; border-radius: 999px;
    background: var(--primary-soft); color: var(--primary);
    font-weight: 700;
  }
  .pcard-read {
    font-size: 10px; color: var(--fg-2); font-family: var(--font-mono);
    margin-left: auto;
  }

  /* Stretch-link pattern: title link covers whole card via ::after */
  .pcard-title {
    font-family: var(--font-display); font-weight: 700;
    font-size: 22px; line-height: 1.25; color: var(--fg-1);
    margin: 0; letter-spacing: -0.015em;
  }
  .pcard-title a {
    color: inherit; text-decoration: none;
    position: relative; display: block;
    transition: color 150ms;
  }
  .pcard-title a::after {
    content: '';
    position: absolute;
    inset: -999px;
    z-index: 0;
  }
  .pcard:hover .pcard-title a { color: var(--primary); }
  .pcard-tint { color: oklch(0.49 0.15 var(--hue)); }
  .dark .pcard-tint { color: var(--primary); }

  .pcard-desc {
    font-size: 13.5px; color: var(--fg-2); line-height: 1.6; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .pcard-tags {
    display: flex; gap: 5px; flex-wrap: wrap;
    position: relative; z-index: 1;
  }
  .pcard-tag {
    font-size: 11px; padding: 2px 8px; border-radius: 999px;
    background: var(--btn-regular-bg); color: var(--fg-3);
    font-family: var(--font-mono);
    transition: background 120ms, color 120ms;
  }
  .pcard-tag:hover { background: var(--primary-soft); color: var(--primary); }

  /* Right media column — a real link so it's always clickable */
  .pcard-media {
    display: flex; align-items: stretch;
    padding: 14px; flex-shrink: 0;
    text-decoration: none;
    position: relative; z-index: 1;
  }
  .pcard-photo {
    position: relative; width: 130px;
    border-radius: 0.75rem; overflow: hidden;
    flex-shrink: 0; align-self: stretch;
  }
  .pcard-photo img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 300ms cubic-bezier(.4,0,.2,1);
  }
  .pcard:hover .pcard-photo img { transform: scale(1.06); }
  .pcard-photo-veil {
    position: absolute; inset: 0; background: rgba(0,0,0,0);
    transition: background 200ms; pointer-events: none;
  }
  .pcard:hover .pcard-photo-veil { background: rgba(0,0,0,0.18); }
  .pcard-photo-chevron {
    position: absolute; inset: 0; margin: auto;
    width: 28px; height: 28px;
    color: white; opacity: 0; transform: scale(0.6);
    transition: opacity 180ms, transform 180ms cubic-bezier(.34,1.56,.64,1);
    pointer-events: none;
  }
  .pcard:hover .pcard-photo-chevron { opacity: 1; transform: scale(1); }

  .pcard-enter {
    width: 48px; align-self: stretch;
    border-radius: 0.75rem;
    background: var(--btn-regular-bg);
    display: flex; align-items: center; justify-content: center;
    transition: background 150ms;
  }
  .pcard-media:hover .pcard-enter { background: var(--primary-soft); }
  .pcard-chevron {
    color: var(--primary); transition: transform 150ms;
  }
  .pcard-media:hover .pcard-chevron { transform: translateX(3px); }

  /* ── Mobile overrides (must live here so they win the cascade) ────── */
  @media (max-width: 640px) {
    /* Featured */
    .post-featured { height: 200px; }
    .featured-title { font-size: 18px; line-height: 1.3; }
    .featured-desc { display: none; }
    .featured-overlay { padding: 14px 16px; }

    /* Category showcase */
    .cat-showcase-grid { grid-template-columns: 1fr 1fr; gap: 6px; }
    .cat-card { padding: 8px 10px; gap: 8px; }
    .cat-card-photo { height: 52px; padding: 0 10px; }
    .cat-icon { width: 32px; height: 32px; }
    .cat-icon-glyph { font-size: 16px; }
    .cat-name { font-size: 12px; }
    .cat-count { font-size: 10px; }

    /* Post cards — vertical layout: image on top, content below */
    .pcard {
      display: flex;
      flex-direction: column-reverse; /* image first visually = last in DOM */
      margin-bottom: 8px;
    }
    /* hide the index number column */
    .pcard-index { display: none; }

    /* image / media block — full width, capped height, gradient fade */
    .pcard-media {
      display: block;
      padding: 0;
      width: 100%;
      text-decoration: none;
      flex-shrink: 0;
      position: relative;
    }
    .pcard-photo {
      width: 100%;
      height: 22vw;
      max-height: 90px;
      min-height: 60px;
      border-radius: 0;
      position: relative;
    }
    .pcard-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    /* gradient fade from image into card body */
    .pcard-photo::after {
      content: '';
      position: absolute;
      inset: 0;
