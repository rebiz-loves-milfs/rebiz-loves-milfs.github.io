---
import Layout from '../layouts/Layout.astro';
---

<Layout pathname="/404" title="404 — Lost">
  <div class="not-found">
    <div class="art" aria-hidden="true">
      <pre class="ascii-cat">
 /\_____/\
(  o   o  )
(  =   =  )
 \ ~w~w~ /
  )     (
 ( | | | )
(__|___|__)
      </pre>
    </div>

    <div class="code-line" aria-hidden="true">
      <span class="prompt">~/mizuki</span>
      <span class="cmd">$ find . -name "this-page"</span>
    </div>
    <div class="code-line error-line" aria-hidden="true">
      <span class="cmd">find: no such file or directory</span>
    </div>

    <h1 class="num">404</h1>

    <p class="subtitle">This page got lost in the fog</p>

    <p class="hint">
      It wandered off into the mist&nbsp;— maybe it was never here,<br />
      or maybe it dissolved like morning frost.
    </p>

    <a href="/" class="btn-home">
      <span class="btn-icon">❀</span>
      Return home
    </a>

    <div class="sakura-scatter" aria-hidden="true">
      <span class="s s1">❀</span>
      <span class="s s2">✦</span>
      <span class="s s3">❀</span>
      <span class="s s4">◈</span>
      <span class="s s5">❀</span>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 120px);
    padding: 2rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* ASCII cat */
  .art {
    margin-bottom: 1.25rem;
  }

  .ascii-cat {
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1.8vw, 0.85rem);
    line-height: 1.45;
    color: var(--primary);
    opacity: 0.75;
    white-space: pre;
    margin: 0;
    animation: float-cat 5s ease-in-out infinite;
    user-select: none;
  }

  /* Terminal lines */
  .code-line {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-3);
    margin-bottom: 0.2rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    user-select: none;
  }

  .prompt {
    color: oklch(0.72 0.16 var(--hue));
    font-weight: 700;
  }

  .cmd {
    color: var(--fg-3);
  }

  .error-line .cmd {
    color: oklch(0.60 0.18 25);
  }

  .dark .error-line .cmd {
    color: oklch(0.78 0.14 25);
  }

  /* Big 404 */
  .num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(5rem, 20vw, 10rem);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0.5rem 0 0;
    background: linear-gradient(
      135deg,
      oklch(0.70 0.18 var(--hue)) 0%,
      oklch(0.80 0.12 calc(var(--hue) + 30)) 50%,
      oklch(0.70 0.18 var(--hue)) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: float-num 6s ease-in-out infinite;
    user-select: none;
  }

  /* Subtitle */
  .subtitle {
    font-family: var(--font-display);
    font-size: clamp(1rem, 3vw, 1.35rem);
    font-weight: 600;
    color: var(--fg-1);
    margin: 0.5rem 0 0;
    letter-spacing: -0.01em;
  }

  /* Hint paragraph */
  .hint {
    font-size: 0.9rem;
    color: var(--fg-3);
    line-height: 1.75;
    max-width: 36ch;
    margin: 0.75rem auto 1.75rem;
  }

  /* Home button */
  .btn-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.6rem;
    border-radius: var(--radius-pill);
    background: var(--btn-regular-bg);
    color: var(--btn-content);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: background 150ms, border-color 150ms, transform 150ms, box-shadow 150ms;
    position: relative;
    z-index: 1;
  }

  .btn-home:hover {
    background: var(--btn-regular-bg-hover);
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px oklch(0.70 0.14 var(--hue) / 0.20);
  }

  .btn-home:active {
    background: var(--btn-regular-bg-active);
    transform: translateY(0);
    box-shadow: none;
  }

  .btn-icon {
    color: var(--primary);
    font-size: 1rem;
    line-height: 1;
  }

  /* Floating petals background scatter */
  .sakura-scatter {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .s {
    position: absolute;
    font-size: clamp(1rem, 3vw, 1.5rem);
    color: var(--primary);
    opacity: 0.18;
    animation: drift linear infinite;
    user-select: none;
  }

  .s1 { left: 8%;  top: 15%; animation-duration: 9s;  animation-delay: 0s;    font-size: 1.2rem; }
  .s2 { left: 80%; top: 20%; animation-duration: 12s; animation-delay: -3s;   font-size: 0.9rem; }
  .s3 { left: 60%; top: 55%; animation-duration: 10s; animation-delay: -6s;   font-size: 1.4rem; }
  .s4 { left: 20%; top: 65%; animation-duration: 14s; animation-delay: -2s;   font-size: 0.8rem; }
  .s5 { left: 45%; top: 10%; animation-duration: 11s; animation-delay: -8s;   font-size: 1.1rem; }

  /* Animations */
  @keyframes float-num {
    0%, 100% { transform: translateY(0);    }
    50%       { transform: translateY(-10px); }
  }

  @keyframes float-cat {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50%       { transform: translateY(-6px) rotate(1deg); }
  }

  @keyframes drift {
    0%   { transform: translateY(0)     rotate(0deg);   opacity: 0.18; }
    50%  { transform: translateY(-18px) rotate(180deg); opacity: 0.10; }
    100% { transform: translateY(0)     rotate(360deg); opacity: 0.18; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .num, .ascii-cat, .s { animation: none; }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .hint { font-size: 0.82rem; }
    .code-line { font-size: 0.7rem; }
  }
</style>
