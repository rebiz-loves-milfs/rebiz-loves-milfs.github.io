---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.svelte';
import Profile from '../components/widget/Profile.astro';
import LastFm from '../components/widget/LastFm.svelte';
import SimklStats from '../components/widget/SimklStats.svelte';
import Watchlist from '../components/Watchlist.svelte';
import { SIMKL } from '../config';
---

<Layout pathname="/movies" title="Movies & Shows">
  <Banner client:load compact title="Movies & Shows" subtitle="Films & series I've been watching" />
  <div class="grid three-col">
    <aside class="sidebar">
      <Profile />
      <SimklStats client:visible user={SIMKL.user} clientId={SIMKL.clientId} />
    </aside>
    <main>
      <div class="card movies-wrap">
        <Watchlist client:load />
      </div>
    </main>
    <aside class="sidebar-right">
      <LastFm client:load />
    </aside>
  </div>
</Layout>

<style>
  .movies-wrap { padding: 20px 18px; min-width: 0; overflow: hidden; }
</style>
