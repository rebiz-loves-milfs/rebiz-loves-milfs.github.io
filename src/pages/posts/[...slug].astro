---
import Layout from '../../layouts/Layout.astro';
import Banner from '../../components/Banner.svelte';
import Profile from '../../components/widget/Profile.astro';
import TOC from '../../components/widget/TOC.astro';
import SeriesNav from '../../components/widget/SeriesNav.astro';
import LastFm from '../../components/widget/LastFm.svelte';
import Discord from '../../components/widget/Discord.svelte';
import Comments from '../../components/Comments.svelte';
import Encryptor from '../../components/Encryptor.astro';
import TimeLock from '../../components/TimeLock.svelte';
import TimeLockEncryptor from '../../components/TimeLockEncryptor.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getSortedPosts, formatDate, formatDateTime, slugify } from '../../utils/content-utils';
import { render } from 'astro:content';
import { GISCUS, SITE, AUTHOR } from '../../config';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { title, titleTinted, published, updated, category, tags, description, readTime, gradient, glyph, image, series, encrypted, password, passwordHint, unlockAt } = post.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description || '',
  datePublished: published.toISOString(),
  ...(updated && { dateModified: updated.toISOString() }),
  author: { '@type': 'Person', name: AUTHOR.name },
  url: `${SITE.url}/posts/${post.id}`,
  ...(image && { image: `${SITE.url}${image}` }),
};
---

<Layout pathname={`/posts/${post.id}`} title={title} description={description} ogImage={image || undefined}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Banner client:load compact title={title} subtitle={description} />
  <div class="grid">
    <aside class="sidebar">
      <Profile />
      <TOC headings={headings} />
      {series && <SeriesNav seriesName={series} currentId={post.id} />}
      <LastFm client:visible />
      <Discord client:visible />
    </aside>
    <main>
      <article class="post-body" style="animation: post-body-in 500ms cubic-bezier(0.16,1,0.3,1) both;">

        <!-- Hero -->
        {image
          ? <div class="post-hero post-hero-img">
              <img src={image} alt={title} loading="eager" width="1200" height="630" style="aspect-ratio:1200/630;object-fit:cover;" />
            </div>
          : <div class="post-hero post-hero-gradient" style={gradient ? `background:${gradient}` : 'background:var(--primary-soft)'}>
              <span class="post-glyph">{glyph || '✦'}</span>
              <div class="post-hero-shimmer"></div>
            </div>
        }

        <!-- Meta badges -->
        <div class="post-meta-bar">
          <span class="meta-pill">
            <iconify-icon icon="material-symbols:calendar-today-outline" width="15"></iconify-icon>
            <time datetime={published.toISOString()}>{formatDate(published)}</time>
          </span>
          {updated && (
            <span class="meta-pill meta-pill-muted">
              <iconify-icon icon="material-symbols:update" width="15"></iconify-icon>
              <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
            </span>
          )}
          {category && (
            <a href={`/category/${slugify(category)}`} class="meta-pill meta-pill-cat">
              <iconify-icon icon="material-symbols:bookmark-outline" width="15"></iconify-icon>
              {category}
            </a>
          )}
          {unlockAt && new Date() < unlockAt && (
            <span class="meta-pill meta-pill-muted">
              <iconify-icon icon="material-symbols:schedule-outline" width="15"></iconify-icon>
              Unlocks {formatDateTime(unlockAt)}
            </span>
          )}
          {readTime && (
            <span class="meta-pill meta-pill-muted">
              <iconify-icon icon="material-symbols:schedule-outline" width="15"></iconify-icon>
              {readTime} read
            </span>
          )}
        </div>

        <!-- Title -->
        <h1 class="post-title">
          {encrypted && <iconify-icon icon="material-symbols:lock-outline" width="28" class="post-lock-icon"></iconify-icon>}
          {title}
          {titleTinted && <span class="tinted"> {titleTinted}</span>}
        </h1>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="tag-row">
            {tags.map(tag => (
              <a href={`/tag/${slugify(tag)}`} class="tag-pill">#{tag}</a>
            ))}
          </div>
        )}

        <!-- Post divider -->
        <div class="post-divider"></div>

        <!-- Content -->
        <div class="post-content">
          {unlockAt
            ? encrypted && password
              ? <TimeLock client:load unlockAt={unlockAt}>
                  <Encryptor password={password} hint={passwordHint}><Content /></Encryptor>
                </TimeLock>
              : <TimeLockEncryptor unlockAt={unlockAt}><Content /></TimeLockEncryptor>
            : encrypted && password
              ? <Encryptor password={password} hint={passwordHint}><Content /></Encryptor>
              : <Content />
          }
        </div>

        <!-- Share / copy -->
        <div class="post-actions" id="post-actions">
          <button class="post-action-btn" id="copy-link-btn" aria-label="Copy link to post">
            <iconify-icon icon="material-symbols:link" width="16"></iconify-icon>
            Copy link
          </button>
          {AUTHOR.socials.twitter && (
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`${SITE.url}/posts/${post.id}`)}`}
              target="_blank" rel="noopener noreferrer"
              class="post-action-btn post-action-twitter"
              aria-label="Share on Twitter"
            >
              <iconify-icon icon="fa7-brands:x-twitter" width="14"></iconify-icon>
              Share
            </a>
          )}
        </div>
        <script>
          const btn = document.getElementById('copy-link-btn');
          if (btn) {
            btn.addEventListener('click', async () => {
              try {
                await navigator.clipboard.writeText(window.location.href);
                btn.innerHTML = '<iconify-icon icon="material-symbols:check" width="16"></iconify-icon> Copied!';
                setTimeout(() => {
                  btn.innerHTML = '<iconify-icon icon="material-symbols:link" width="16"></iconify-icon> Copy link';
                }, 2000);
              } catch {}
            });
          }
        </script>

        <!-- Comments -->
        <Comments
          client:visible
          repo={GISCUS.repo}
          repoId={GISCUS.repoId}
          category={GISCUS.category}
          categoryId={GISCUS.categoryId}
        />

        <!-- Related posts -->
        <RelatedPosts currentId={post.id} tags={tags} category={category ?? ''} />

        <!-- Back -->
        <div class="post-footer">
          <a href="/" class="btn-back">
            <iconify-icon icon="material-symbols:arrow-back" width="14"></iconify-icon>
            Back to posts
          </a>
        </div>
      </article>
    </main>
  </div>
</Layout>

<style>
  /* Hero */
  .post-hero {
    width: 100%; border-radius: var(--radius-large);
    margin-bottom: 28px; overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }
  .post-hero-img { aspect-ratio: 16 / 6; }
  .post-hero-img img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 600ms cubic-bezier(0.16,1,0.3,1);
  }
  .post-hero-img:hover img { transform: scale(1.02); }
  .post-hero-gradient {
    height: 220px; position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .post-glyph {
    font-size: 96px; opacity: 0.6;
    filter: drop-shadow(0 4px 24px rgba(0,0,0,0.2));
    position: relative; z-index: 1;
    animation: glyph-float 6s ease-in-out infinite;
  }
  @keyframes glyph-float {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50%       { transform: translateY(-8px) rotate(2deg); }
  }
  .post-hero-shimmer {
    position: absolute; inset: 0;
    background: linear-gradient(135deg,
      rgba(255,255,255,0.12) 0%,
      transparent 50%,
      oklch(0.70 0.10 var(--hue) / 0.05) 100%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .post-glyph { animation: none; }
    .post-hero-img:hover img { transform: none; }
  }

  /* Meta bar */
  .post-meta-bar {
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
    margin-bottom: 20px;
  }
  .meta-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 999px;
    font-size: 13.5px; font-family: var(--font-mono);
    background: var(--btn-regular-bg); color: var(--btn-content);
    white-space: nowrap;
  }
  .meta-pill iconify-icon { width: 14px; height: 14px; flex-shrink: 0; }
  .meta-pill-muted { color: var(--fg-3); background: transparent; border: 1px solid var(--border); }
  .meta-pill-cat {
    background: var(--primary-soft); color: var(--primary);
    text-decoration: none; font-weight: 600;
    transition: background 120ms;
  }
  .meta-pill-cat:hover { background: var(--btn-regular-bg-hover); }

  .post-lock-icon {
    color: var(--primary);
    vertical-align: middle;
    margin-right: 6px;
    opacity: 0.8;
  }

  /* Title */
  .post-title {
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(30px, 4.5vw, 52px);
    line-height: 1.1; color: var(--fg-1);
    margin: 0 0 16px; letter-spacing: -0.025em;
  }
  .post-title .tinted { color: var(--primary); }

  /* Tags */
  .tag-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
  .tag-pill {
    font-size: 12px; padding: 4px 12px; border-radius: 999px;
    background: var(--primary-soft); color: var(--primary);
    font-family: var(--font-display); text-decoration: none;
    border: 1px solid transparent;
    transition: background 200ms, transform 200ms cubic-bezier(0.34,1.56,0.64,1), border-color 200ms;
  }
  .tag-pill:hover {
    background: var(--btn-regular-bg-hover);
    border-color: oklch(0.70 0.14 var(--hue) / 0.3);
    transform: translateY(-2px);
  }

  /* Divider */
  .post-divider {
    height: 1px; margin: 28px 0; border-radius: 1px;
    background: linear-gradient(to right, var(--primary), var(--primary-soft), transparent);
    opacity: 0.5;
  }

  /* Content prose overrides */
  .post-content :global(h2) { scroll-margin-top: 110px; }
  .post-content :global(h3) { scroll-margin-top: 110px; }
  .post-content :global(p) { font-size: 16.5px; line-height: 1.9; }
  .post-content :global(img) {
    border-radius: var(--radius-large);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    max-width: 100%;
  }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: 1.5em; line-height: 1.85;
    font-size: 16px; color: var(--fg-2);
  }
  .post-content :global(li) { margin-bottom: 6px; }
  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border), transparent);
    margin: 32px 0;
  }

  /* Share / copy actions */
  .post-actions {
    display: flex; gap: 10px; flex-wrap: wrap;
    margin-top: 48px; padding-top: 28px;
    border-top: 1px solid var(--border);
  }
  .post-action-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 18px; border-radius: 999px;
    font-size: 13px; font-family: var(--font-display); font-weight: 600;
    background: var(--btn-regular-bg); color: var(--btn-content);
    border: 1px solid var(--border); cursor: pointer;
    text-decoration: none;
    transition: background 200ms, transform 200ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 200ms;
  }
  .post-action-btn:hover {
    background: var(--btn-regular-bg-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  .post-action-twitter {
    background: var(--primary-soft); color: var(--primary);
    border-color: oklch(0.70 0.14 var(--hue) / 0.2);
  }
  .post-action-twitter:hover {
    background: var(--primary);
    color: white;
    border-color: transparent;
    box-shadow: 0 4px 16px oklch(0.70 0.14 var(--hue) / 0.35);
  }

  /* Article entrance */
  @keyframes post-body-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    article.post-body { animation: none; }
    .tag-pill:hover { transform: none; }
  }

  /* Footer */
  .post-footer { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border); }
  .btn-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--fg-2); text-decoration: none; transition: color 0.2s;
  }
  .btn-back:hover { color: var(--primary); }

  @media (prefers-reduced-motion: reduce) {
    .copy-code-btn { transition: none; }
  }
</style>

<script>
  function initCopyCodeButtons() {
    const pres = document.querySelectorAll('.post-content pre');
    pres.forEach((pre) => {
      // Idempotency check — skip if already wrapped
      if (pre.parentElement && pre.parentElement.classList.contains('code-block-wrap')) return;

      // Wrap the pre in a relative container
      const wrap = document.createElement('div');
      wrap.className = 'code-block-wrap';
      pre.parentNode.insertBefore(wrap, pre);
      wrap.appendChild(pre);

      // Build button
      const btn = document.createElement('button');
      btn.className = 'copy-code-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>Copy`;
      wrap.appendChild(btn);

      btn.addEventListener('click', async () => {
        const text = pre.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // Fallback for browsers without clipboard API
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
          document.body.appendChild(ta);
          ta.focus();
          ta.select();
          try { document.execCommand('copy'); } catch {}
          document.body.removeChild(ta);
        }
        btn.textContent = '✓ Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>Copy`;
          btn.classList.remove('copied');
        }, 2000);
      });
    });
  }

  // Initial load
  initCopyCodeButtons();

  // View Transitions compatibility
  document.addEventListener('astro:page-load', initCopyCodeButtons);
</script>
