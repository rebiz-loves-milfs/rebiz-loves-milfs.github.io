---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.svelte';
import Profile from '../components/widget/Profile.astro';
import SiteStats from '../components/widget/SiteStats.astro';
import LastFm from '../components/widget/LastFm.svelte';
import AnimeList from '../components/AnimeList.svelte';
import AniListStats from '../components/widget/AniListStats.svelte';
import { ANILIST_USER } from '../config';
---

<Layout pathname="/anime" title="Anime">
  <Banner client:load compact title="Anime" subtitle="What I've been watching" />
  <div class="grid three-col">
    <aside class="sidebar">
      <Profile />
      <SiteStats />

      <!-- quick faves -->
      <div class="card faves-card">
        <div class="widget-title">All-time picks</div>
        <div class="faves-list">
          <div class="fave-row">
            <span class="fave-glyph" style="background:linear-gradient(135deg,oklch(0.82 0.12 25),oklch(0.55 0.22 30))">♡</span>
            <span class="fave-name">Spice and Wolf</span>
          </div>
          <div class="fave-row">
            <span class="fave-glyph" style="background:linear-gradient(135deg,oklch(0.82 0.10 160),oklch(0.55 0.16 150))">✦</span>
            <span class="fave-name">Frieren</span>
          </div>
          <div class="fave-row">
            <span class="fave-glyph" style="background:linear-gradient(135deg,oklch(0.80 0.10 200),oklch(0.55 0.16 220))">◇</span>
            <span class="fave-name">A Place Further Than the Universe</span>
          </div>
          <div class="fave-row">
            <span class="fave-glyph" style="background:linear-gradient(135deg,oklch(0.82 0.10 270),oklch(0.55 0.16 280))">✿</span>
            <span class="fave-name">Violet Evergarden</span>
          </div>
          <div class="fave-row">
            <span class="fave-glyph" style="background:linear-gradient(135deg,oklch(0.82 0.10 80),oklch(0.55 0.18 90))">⌘</span>
            <span class="fave-name">Made in Abyss</span>
          </div>
        </div>
      </div>

      <LastFm client:load />
    </aside>

    <main>
      <AniListStats client:visible user={ANILIST_USER} full />
      <div class="card anime-wrap">
        <AnimeList client:load user={ANILIST_USER} />
      </div>
    </main>

    <aside class="sidebar-right">
      <!-- genre taste -->
      <div class="card">
        <div class="widget-title">Genres I love</div>
        <div class="genre-list">
          {[
            { label: 'Slice of Life',   hue: 100, icon: 'material-symbols:local-florist-outline' },
            { label: 'Fantasy',         hue: 280, icon: 'material-symbols:auto-awesome-outline' },
            { label: 'Mystery',         hue: 230, icon: 'material-symbols:search-outline' },
            { label: 'Drama',           hue: 25,  icon: 'material-symbols:theater-comedy-outline' },
            { label: 'Adventure',       hue: 160, icon: 'material-symbols:hiking-outline' },
          ].map(g => (
            <div class="genre-row" style={`--g-hue:${g.hue}`}>
              <span class="genre-dot"></span>
              <iconify-icon icon={g.icon} width="13"></iconify-icon>
              <span class="genre-label">{g.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- quote -->
      <div class="card quote-card">
        <div class="widget-title">Quote</div>
        <blockquote class="anime-quote">
          "The world is not beautiful. Therefore, it is."
        </blockquote>
        <p class="quote-source">— Kino's Journey</p>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .anime-wrap { padding: 20px 18px; min-width: 0; overflow: hidden; }

  /* all-time faves widget */
  .faves-card { background: var(--card-bg); border-radius: var(--radius-large); padding: 16px 18px; }
  .faves-list { display: flex; flex-direction: column; gap: 8px; }
  .fave-row {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; color: var(--fg-1);
  }
  .fave-glyph {
    width: 28px; height: 28px; border-radius: 0.5rem;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; color: white; flex-shrink: 0;
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }
  .fave-name { font-size: 12.5px; color: var(--fg-2); line-height: 1.3; }

  /* genres widget */
  .genre-list { display: flex; flex-direction: column; gap: 6px; }
  .genre-row {
    display: flex; align-items: center; gap: 7px;
    font-size: 13px; color: var(--fg-2);
  }
  .genre-dot {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    background: oklch(0.70 0.14 var(--g-hue));
  }
  .genre-label { font-size: 12.5px; }

  /* quote widget */
  .quote-card { background: var(--card-bg); border-radius: var(--radius-large); padding: 16px 18px; }
  .anime-quote {
    font-family: var(--font-display);
    font-size: 13.5px; font-style: italic;
    color: var(--fg-2); line-height: 1.6;
    margin: 0 0 8px;
    border-left: 2px solid var(--primary);
    padding-left: 10px;
  }
  .quote-source {
    font-size: 11px; color: var(--fg-3);
    font-family: var(--font-mono); margin: 0;
  }
</style>
