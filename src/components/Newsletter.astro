---
// Newsletter.astro — Static newsletter signup UI (no backend)
---

<div class="newsletter-widget card">
  <div class="newsletter-inner">
    <h4 class="newsletter-heading">Stay in the loop</h4>
    <p class="newsletter-sub">Get new posts delivered to your inbox. No spam, ever.</p>

    <form class="newsletter-form" novalidate id="newsletter-form">
      <div class="newsletter-row">
        <input
          type="email"
          id="newsletter-email"
          name="email"
          placeholder="your@email.com"
          aria-label="Email address for newsletter"
          class="newsletter-input"
          autocomplete="email"
        />
        <button
          type="submit"
          class="newsletter-btn"
          aria-label="Subscribe to newsletter"
        >
          <iconify-icon icon="material-symbols:mail-outline" width="18" height="18"></iconify-icon>
          <span>Subscribe</span>
        </button>
      </div>
      <p class="newsletter-msg" id="newsletter-msg" aria-live="polite"></p>
    </form>

    <p class="newsletter-note">Unsubscribe anytime. Your data stays with you.</p>
  </div>
</div>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg') as HTMLElement | null;

  if (form && msg) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      msg.textContent = 'Subscribe functionality coming soon!';
      msg.classList.add('newsletter-msg--visible');
    });
  }
</script>

<style>
  .newsletter-widget {
    margin-bottom: 14px;
  }

  .newsletter-inner {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .newsletter-heading {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--fg-1);
    margin: 0;
  }

  .newsletter-sub {
    font-size: 13px;
    color: var(--fg-2);
    margin: 0;
    line-height: 1.5;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .newsletter-row {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    padding: 8px 12px;
    border-radius: var(--radius-large);
    border: 1px solid var(--border);
    background: var(--btn-regular-bg);
    color: var(--fg-1);
    font-size: 13px;
    outline: none;
    transition: border-color 120ms;
  }

  .newsletter-input::placeholder {
    color: var(--fg-3);
  }

  .newsletter-input:focus {
    border-color: var(--primary);
  }

  .newsletter-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: var(--radius-large);
    background: var(--primary);
    color: white;
    border: none;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 120ms;
  }

  .newsletter-btn:hover {
    opacity: 0.88;
  }

  .newsletter-msg {
    font-size: 12px;
    color: var(--primary);
    margin: 0;
    min-height: 1em;
    opacity: 0;
    transition: opacity 200ms;
  }

  .newsletter-msg--visible {
    opacity: 1;
  }

  .newsletter-note {
    font-size: 11px;
    color: var(--fg-3);
    margin: 0;
  }
</style>
